generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  STUDENT
  ADMIN
}

enum BookStatus {
  UPLOADED
  PROCESSING
  PROCESSED
  FAILED
}

enum ChunkType {
  TASK
  THEORY
  EXAMPLE
  OTHER
}

enum NodeType {
  CONCEPT
  TASK
  SECTION
}

enum EdgeType {
  SIMILAR
  DEPENDS_ON
  NEXT
  PART_OF
}

enum MessageRole {
  USER
  ASSISTANT
}

model User {
  id           String        @id @default(cuid())
  email        String        @unique
  name         String?
  role         UserRole      @default(STUDENT)
  password     String
  books        Book[]
  chatSessions ChatSession[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model Book {
  id           String        @id @default(cuid())
  userId       String
  user         User          @relation(fields: [userId], references: [id])
  title        String
  status       BookStatus    @default(UPLOADED)
  pages        BookPage[]
  chunks       BookChunk[]
  nodes        GraphNode[]
  edges        GraphEdge[]
  chatSessions ChatSession[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model BookPage {
  id         String      @id @default(cuid())
  bookId     String
  book       Book        @relation(fields: [bookId], references: [id])
  pageNumber Int
  rawText    String      @db.Text
  ocrMeta    Json?
  chunks     BookChunk[]
  createdAt  DateTime    @default(now())
}

model BookChunk {
  id        String      @id @default(cuid())
  bookId    String
  book      Book        @relation(fields: [bookId], references: [id])
  pageId    String
  page      BookPage    @relation(fields: [pageId], references: [id])
  type      ChunkType   @default(OTHER)
  content   String      @db.Text
  position  Int
  embedding Embedding?
  graphNodes GraphNode[]
  createdAt DateTime    @default(now())
}

model Embedding {
  id        String    @id @default(cuid())
  chunkId   String    @unique
  chunk     BookChunk @relation(fields: [chunkId], references: [id])
  vector    Bytes
  provider  String    @default("openai")
  createdAt DateTime  @default(now())
}

model GraphNode {
  id        String      @id @default(cuid())
  bookId    String
  book      Book        @relation(fields: [bookId], references: [id])
  chunkId   String?
  chunk     BookChunk?  @relation(fields: [chunkId], references: [id])
  type      NodeType
  label     String
  outgoing  GraphEdge[] @relation("Source")
  incoming  GraphEdge[] @relation("Target")
  createdAt DateTime    @default(now())
}

model GraphEdge {
  id       String   @id @default(cuid())
  bookId   String
  book     Book     @relation(fields: [bookId], references: [id])
  sourceId String
  source   GraphNode @relation("Source", fields: [sourceId], references: [id])
  targetId String
  target   GraphNode @relation("Target", fields: [targetId], references: [id])
  type     EdgeType
  weight   Float    @default(1.0)

  @@index([bookId])
  @@index([sourceId])
  @@index([targetId])
}

model ChatSession {
  id        String        @id @default(cuid())
  userId    String
  user      User          @relation(fields: [userId], references: [id])
  bookId    String
  book      Book          @relation(fields: [bookId], references: [id])
  messages  ChatMessage[]
  createdAt DateTime      @default(now())
  endedAt   DateTime?
}

model ChatMessage {
  id             String      @id @default(cuid())
  sessionId      String
  session        ChatSession @relation(fields: [sessionId], references: [id])
  role           MessageRole
  content        String      @db.Text
  createdAt      DateTime    @default(now())
  avatarVideoUrl String?
}
