generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "windows"]
}

datasource db {
  provider  = "postgresql"
}

enum UserRole {
  STUDENT
  ADMIN
}

enum SessionStatus {
  UPLOADED
  PROCESSING
  PROCESSED
  FAILED
}

enum ChunkType {
  TASK
  THEORY
  EXAMPLE
  OTHER
}

enum NodeType {
  CONCEPT
  TASK
  SECTION
}

enum EdgeType {
  SIMILAR
  DEPENDS_ON
  NEXT
  PART_OF
}

enum MessageRole {
  USER
  ASSISTANT
}

model User {
  id               String            @id @default(cuid())
  email            String            @unique
  name             String?
  role             UserRole          @default(STUDENT)
  password         String
  learningSessions LearningSession[]
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  aiMinutesUsed    Int               @default(0)
  aiMinutesLimit   Int               @default(10)
  subscriptionPlan String            @default("Uczeń")
}

model LearningSession {
  id        String          @id @default(cuid())
  userId    String
  user      User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  topic     String
  status    SessionStatus   @default(UPLOADED)
  summary   String?         @db.Text
  chunks    SessionChunk[]
  nodes     GraphNode[]
  edges     GraphEdge[]
  messages  ChatMessage[]
  flashcardSets FlashcardSet[]
  mindMapNodes  MindMapNode[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

model SessionChunk {
  id        String          @id @default(cuid())
  sessionId String
  session   LearningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  type      ChunkType       @default(OTHER)
  content   String          @db.Text
  position  Int
  embedding Embedding?
  graphNodes GraphNode[]
  mindMapNodes MindMapNode[]
  createdAt DateTime        @default(now())
}

model Embedding {
  id        String       @id @default(cuid())
  chunkId   String       @unique
  chunk     SessionChunk @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  vector    Unsupported("vector(1536)")
  provider  String       @default("openai")
  createdAt DateTime     @default(now())
}

model GraphNode {
  id        String          @id @default(cuid())
  sessionId String
  session   LearningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  chunkId   String?
  chunk     SessionChunk?   @relation(fields: [chunkId], references: [id], onDelete: Cascade)
  type      NodeType
  label     String
  outgoing  GraphEdge[]     @relation("Source")
  incoming  GraphEdge[]     @relation("Target")
  createdAt DateTime        @default(now())
}

model GraphEdge {
  id        String          @id @default(cuid())
  sessionId String
  session   LearningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  sourceId  String
  source    GraphNode       @relation("Source", fields: [sourceId], references: [id], onDelete: Cascade)
  targetId  String
  target    GraphNode       @relation("Target", fields: [targetId], references: [id], onDelete: Cascade)
  type      EdgeType
  weight    Float           @default(1.0)

  @@index([sessionId])
  @@index([sourceId])
  @@index([targetId])
}

model ChatMessage {
  id             String          @id @default(cuid())
  sessionId      String
  session        LearningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  role           MessageRole
  content        String          @db.Text
  createdAt      DateTime        @default(now())
  avatarVideoUrl String?
}

model FlashcardSet {
  id          String          @id @default(cuid())
  sessionId   String
  session     LearningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  title       String
  sourceType  String          // "summary" | "node" | "query"
  sourceId    String?         // nodeId lub query
  cards       Flashcard[]
  createdAt   DateTime        @default(now())
}

model Flashcard {
  id        String       @id @default(cuid())
  setId     String
  set       FlashcardSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  question  String
  answer    String
  position  Int
  createdAt DateTime     @default(now())
}

model MindMapNode {
  id        String          @id @default(cuid())
  sessionId String
  session   LearningSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  label     String
  type      String          // "root" | "chapter" | "section" | "concept" | "task"
  parentId  String?
  parent    MindMapNode?    @relation("MindMapHierarchy", fields: [parentId], references: [id], onDelete: Cascade)
  children  MindMapNode[]   @relation("MindMapHierarchy")
  chunkId   String?
  chunk     SessionChunk?   @relation(fields: [chunkId], references: [id], onDelete: SetNull)
  position  Int
  createdAt DateTime        @default(now())
}
